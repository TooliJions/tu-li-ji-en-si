{
  "name": "@cybernovelist/core",
  "version": "7.0.0",
  "private": true,
  "description": "CyberNovelist core engine — Agent system, pipeline, state management, governance, quality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "default": "./dist/pipeline/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "default": "./dist/state/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "default": "./dist/agents/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "default": "./dist/llm/index.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "default": "./dist/governance/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "default": "./dist/export/index.js"
    },
    "./quality": {
      "types": "./dist/quality/index.d.ts",
      "default": "./dist/quality/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "adm-zip": "^0.5.17",
    "openai": "^4.77.0",
    "sql.js": "^1.14.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
